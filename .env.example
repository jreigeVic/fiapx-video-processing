# Platform configuration placeholders. See docs/setup/platform-setup.md.
# Never store real credentials in this file.

# GitHub Container Registry (GHCR)
GHCR_USERNAME=<your-github-username>
GHCR_TOKEN=<personal-access-token-with-write-packages-scope>

# SonarCloud
SONAR_TOKEN=<sonarcloud-token>
SONAR_ORGANIZATION=<sonarcloud-organization-key>
SONAR_PROJECT_KEY=<sonarcloud-project-key>

# New Relic
NEW_RELIC_LICENSE_KEY=<new-relic-license-key>

# AWS Academy Lab (temporary session credentials)
AWS_ACCESS_KEY_ID=<aws-academy-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-academy-secret-access-key>
AWS_SESSION_TOKEN=<aws-academy-session-token>
# Real default (not a placeholder): app services fall back to this for
# LocalStack, and it's a normal, valid AWS region to point at in production too.
AWS_REGION=us-east-1

# PostgreSQL (local development only, via Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_MULTIPLE_DATABASES=auth_db,video_db,processing_db,notification_db

# LocalStack (AWS service emulation for local development, via Docker Compose)
LOCALSTACK_HOST=localstack
LOCALSTACK_PORT=4566
LOCALSTACK_SERVICES=s3,sns,sqs,ses
LOCALSTACK_DEBUG=0
LOCALSTACK_PERSISTENCE=1

# JWT signing secret shared by identity-service (issues) and video-service
# (validates), via Docker Compose. Dev-only default matches each service's
# own application.yml fallback - override with a real secret outside local dev.
JWT_SECRET=CHANGE_ME_DEV_ONLY_SECRET_KEY_MIN_32_BYTES_LONG_0000
